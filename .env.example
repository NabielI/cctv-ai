# ── CCTV AI Project - Environment Variables ──
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit .env ke git!

# ── AI Service Config ──
# Jumlah kamera maksimal yang bisa menjalankan AI bersamaan
# Raspi 4: 2-4 (terbatas RAM/CPU)
# Laptop/PC kuat: 8-16
MAX_CONCURRENT_AI_CAMERAS=2

# ── Optional: Force OpenVINO (default OFF karena model di Raspi corrupt) ──
# Set ke 1 jika sudah rebuild OpenVINO model dan mau test
FORCE_OPENVINO=0

# ── Optional: Device override untuk YOLO ──
# Biasanya auto-detect (cuda jika ada GPU, cpu jika tidak)
# FORCE_DEVICE=cpu

# ── Python / Uvicorn ──
PYTHONUNBUFFERED=1
OPENVINO_TELEMETRY_OPTOUT=1
OV_TELEMETRY_OPTOUT=1
